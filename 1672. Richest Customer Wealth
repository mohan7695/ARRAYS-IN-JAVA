class Solution {
    public int maxiamumWealth(int[][] accounts) {
        int n=accounts.length;
      int max=0;
      
        for(int i=0;i<n;i++){
                int d=0;
            for(int j=0;j<accounts[i].length;j++){
                 d=d+accounts[i][j];

               
            }
            max=Math.max(d,max);
        }
        return max;
    }
}
